---
interface Props {
  label: string
  screenId: string
  icon?: 'document' | 'folder' | 'person' | 'mail' | 'photo'
}
const { label, screenId, icon = 'document' } = Astro.props
---

<button class="mobile-icon" data-screen={screenId}>
  <div class="mobile-icon__img">
    {icon === 'document' && (
      <svg viewBox="0 0 40 48" xmlns="http://www.w3.org/2000/svg">
        <path d="M4,2 L28,2 L36,10 L36,46 L4,46 Z" fill="white" stroke="black" stroke-width="2"/>
        <path d="M28,2 L28,10 L36,10" fill="none" stroke="black" stroke-width="2"/>
        <line x1="10" y1="18" x2="30" y2="18" stroke="black" stroke-width="1.5"/>
        <line x1="10" y1="24" x2="30" y2="24" stroke="black" stroke-width="1.5"/>
        <line x1="10" y1="30" x2="24" y2="30" stroke="black" stroke-width="1.5"/>
      </svg>
    )}
    {icon === 'folder' && (
      <svg viewBox="0 0 48 40" xmlns="http://www.w3.org/2000/svg">
        <path d="M2,8 L2,38 L46,38 L46,12 L20,12 L16,8 Z" fill="white" stroke="black" stroke-width="2"/>
        <path d="M2,14 L46,14 L46,38 L2,38 Z" fill="white" stroke="black" stroke-width="2"/>
      </svg>
    )}
    {icon === 'person' && (
      <svg viewBox="0 0 40 48" xmlns="http://www.w3.org/2000/svg">
        <circle cx="20" cy="14" r="10" fill="white" stroke="black" stroke-width="2"/>
        <path d="M2,46 Q2,28 20,28 Q38,28 38,46" fill="white" stroke="black" stroke-width="2"/>
      </svg>
    )}
    {icon === 'mail' && (
      <svg viewBox="0 0 48 40" xmlns="http://www.w3.org/2000/svg">
        <rect x="2" y="4" width="44" height="32" fill="white" stroke="black" stroke-width="2"/>
        <path d="M2,4 L24,22 L46,4" fill="none" stroke="black" stroke-width="2"/>
      </svg>
    )}
    {icon === 'photo' && (
      <svg viewBox="0 0 48 40" xmlns="http://www.w3.org/2000/svg">
        <rect x="2" y="6" width="44" height="32" fill="white" stroke="black" stroke-width="2"/>
        <circle cx="24" cy="22" r="8" fill="none" stroke="black" stroke-width="2"/>
        <circle cx="24" cy="22" r="3" fill="black"/>
        <rect x="16" y="2" width="16" height="6" rx="2" fill="white" stroke="black" stroke-width="2"/>
      </svg>
    )}
  </div>
  <span class="mobile-icon__label">{label}</span>
</button>

<script>
  document.querySelectorAll('.mobile-icon').forEach(icon => {
    icon.addEventListener('click', () => {
      const screenId = icon.getAttribute('data-screen')
      document.getElementById('mobile-grid')?.classList.add('mobile-grid--hidden')
      document.querySelectorAll('.mobile-screen').forEach(s => s.classList.add('mobile-screen--hidden'))
      const screen = document.getElementById(screenId!)
      screen?.classList.remove('mobile-screen--hidden')
    })
  })
</script>