---
interface Props {
  label: string
  screenId: string
  icon: string
}

const { label, screenId, icon } = Astro.props
---

<button class="mobile-icon" data-screen={screenId}>
  <div class="mobile-icon__img">
    <img src={`/icons/${icon}.svg`} alt={label} />
  </div>
  <span class="mobile-icon__label">{label}</span>
</button>

<script>
  document.querySelectorAll('.mobile-icon').forEach(icon => {
    icon.addEventListener('click', () => {
      const screenId = icon.getAttribute('data-screen')
      document.getElementById('mobile-grid')?.classList.add('mobile-grid--hidden')
      document.querySelectorAll('.mobile-screen').forEach(s => s.classList.add('mobile-screen--hidden'))
      const screen = document.getElementById(screenId!)
      screen?.classList.remove('mobile-screen--hidden')
    })
  })
</script>