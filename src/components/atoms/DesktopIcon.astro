---
interface Props {
  label: string
  windowId: string
  icon?: 'folder' | 'document' | 'person' | 'mail'
}

const { label, windowId, icon = 'document' } = Astro.props
---

<button class="desktop-icon" data-window={windowId}>
  <div class="desktop-icon__img">
    {icon === 'folder' && (
      <svg viewBox="0 0 48 40" xmlns="http://www.w3.org/2000/svg">
        <path d="M2,8 L2,38 L46,38 L46,12 L20,12 L16,8 Z" fill="white" stroke="black" stroke-width="1.5"/>
        <path d="M2,14 L46,14 L46,38 L2,38 Z" fill="white" stroke="black" stroke-width="1.5"/>
      </svg>
    )}
    {icon === 'document' && (
      <svg viewBox="0 0 40 48" xmlns="http://www.w3.org/2000/svg">
        <path d="M4,2 L28,2 L36,10 L36,46 L4,46 Z" fill="white" stroke="black" stroke-width="1.5"/>
        <path d="M28,2 L28,10 L36,10" fill="none" stroke="black" stroke-width="1.5"/>
        <line x1="10" y1="18" x2="30" y2="18" stroke="black" stroke-width="1"/>
        <line x1="10" y1="24" x2="30" y2="24" stroke="black" stroke-width="1"/>
        <line x1="10" y1="30" x2="24" y2="30" stroke="black" stroke-width="1"/>
      </svg>
    )}
    {icon === 'person' && (
      <svg viewBox="0 0 40 48" xmlns="http://www.w3.org/2000/svg">
        <circle cx="20" cy="14" r="10" fill="white" stroke="black" stroke-width="1.5"/>
        <path d="M2,46 Q2,28 20,28 Q38,28 38,46" fill="white" stroke="black" stroke-width="1.5"/>
      </svg>
    )}
    {icon === 'mail' && (
      <svg viewBox="0 0 48 40" xmlns="http://www.w3.org/2000/svg">
        <rect x="2" y="4" width="44" height="32" fill="white" stroke="black" stroke-width="1.5"/>
        <path d="M2,4 L24,22 L46,4" fill="none" stroke="black" stroke-width="1.5"/>
      </svg>
    )}
  </div>
  <span class="desktop-icon__label">{label}</span>
</button>

<script>
  document.querySelectorAll('.desktop-icon').forEach(icon => {
    icon.addEventListener('click', () => {
      const windowId = icon.getAttribute('data-window')
      const win = document.getElementById(windowId!)
      win?.classList.remove('window--hidden')
      win!.style.zIndex = '100'
    })
  })
</script>