---
interface Props {
  id: string
}
const { id } = Astro.props
---

<div class="youtube-embed">
  <iframe
    src={`https://www.youtube.com/embed/${id}`}
    title="YouTube video"
    frameborder="0"
    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
    allowfullscreen
  ></iframe>
</div>