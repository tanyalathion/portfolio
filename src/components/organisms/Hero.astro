---
interface Props {
  label?: string
  meta?: string[]
}

const { label = 'Product Designer & Developer', meta = [] } = Astro.props
---

<section class="hero">
  <div class="hero__label">{label}</div>
  <h1>Interface systems<br>for <em>complex institutions</em></h1>
  {meta.length > 0 && (
    <div class="hero__meta">
      {meta.map(m => <span>{m}</span>)}
    </div>
  )}
</section>