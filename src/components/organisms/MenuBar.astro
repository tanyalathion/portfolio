---
---

<header class="menubar">
  
  <div class="menubar__left">
  <button class="menubar__apple">
    <img src="/favicon-tl.svg" alt="TL" class="menubar__logo" />
  </button>
  <div class="menubar__title">
    <span class="menubar__name">Tanya Lathion</span>
    <span class="menubar__baseline">Design. Ship. Bridge.</span>
  </div>
</div>

  <div class="menubar__right">
    <a href="https://github.com/tanyalathion" target="_blank" class="menubar__link">GitHub</a>
    <a href="https://www.linkedin.com/in/tanya-lathion" target="_blank" class="menubar__link">LinkedIn</a>
    <span class="menubar__clock" id="menubar-clock"></span>
  </div>
</header>

<script>
  function updateClock() {
    const clock = document.getElementById('menubar-clock')
    if (clock) {
      const now = new Date()
      clock.textContent = now.toLocaleTimeString('fr-CH', {
        hour: '2-digit',
        minute: '2-digit'
      })
    }
  }
  updateClock()
  setInterval(updateClock, 1000)
</script>