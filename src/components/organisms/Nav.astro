---
const links = [
  { label: 'Work', href: '/work' },
  { label: 'System', href: '/system' },
  { label: 'Writing', href: '/writing' },
  { label: 'About', href: '/about' },
]

const currentPath = Astro.url.pathname
---

<nav class="nav">
  <a href="/" class="nav__logo">TL <span>·</span> Tanya Lathion</a>
  <div class="nav__links">
    {links.map(l => (
      
        href={l.href}
        class:list={['nav__link', { 'nav__link--active': currentPath.startsWith(l.href) }]}
      >
        {l.label}
      </a>
    ))}
  </div>
</nav>