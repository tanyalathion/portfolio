---
import '../styles/global.scss'
import MenuBar from '../components/organisms/MenuBar.astro'

interface Props {
  title?: string
}

const { title = 'Tanya Lathion' } = Astro.props
---

<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon-tl.svg" />
  </head>
  <body>
    <MenuBar />
    <div class="desktop">
      <slot />
    </div>
  </body>
</html>