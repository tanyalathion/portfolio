---
import Base from '../layouts/Base.astro'
import Window from '../components/organisms/Window.astro'
import DesktopIcon from '../components/atoms/DesktopIcon.astro'
import { getCollection } from 'astro:content'
import Case from '../components/organisms/windows/Case.astro'
import About from '../components/organisms/windows/About.astro'
import Contact from '../components/organisms/windows/Contact.astro'
import Oldies from '../components/organisms/windows/Oldies.astro'

const workItems = (await getCollection('work'))
  .sort((a, b) => Number(b.data.year) - Number(a.data.year))
---

<Base title="Tanya Lathion">

  <div class="desktop-icons">
  <div class="desktop-icons__row">
    {workItems.map(item => (
      <DesktopIcon
        label={item.data.title}
        windowId={`win-${item.id}`}
        icon="document"
      />
    ))}
  </div>
  <div class="desktop-icons__row">
    <DesktopIcon label="About" windowId="win-about" icon="folder" />
    <DesktopIcon label="Contact" windowId="win-contact" icon="folder" />
    <DesktopIcon label="Oldies" windowId="win-oldies" icon="folder" />
  </div>
</div>

  {workItems.map((item, i) => (
  <Window title={item.data.title} id={`win-${item.id}`} x={120 + i * 30} y={60 + i * 30} width={640} hidden={true}>
    <Case item={item} />
  </Window>
))}

<Window title="About" id="win-about" x={200} y={60} width={560} hidden={true}>
  <About />
</Window>

<Window title="Contact" id="win-contact" x={300} y={80} width={400} hidden={true}>
  <Contact />
</Window>

<Window title="Oldies" id="win-oldies" x={150} y={70} width={740} hidden={true}>
  <Oldies />
</Window>

</Base>