---
import Base from '../layouts/Base.astro'
import Hero from '../components/organisms/Hero.astro'
import CaseItem from '../components/molecules/CaseItem.astro'
import BlogRow from '../components/molecules/BlogRow.astro'
import { getCollection } from 'astro:content'

const workItems = await getCollection('work')

const cases = workItems
  .sort((a, b) => Number(b.data.year) - Number(a.data.year))
  .map((item, i) => ({
    num: `0${i + 1}`,
    title: item.data.title,
    desc: item.data.subtitle,
    year: item.data.year,
    tags: item.data.tags.map((t, ti) => ({ label: t, accent: ti === 0 })),
    href: `/work/${item.id.replace('.md', '')}`
  }))
const posts = [
  {
    date: '12 Jan 2025',
    title: 'Semantic tokens in TYPO3 — why the extra layer matters',
    excerpt: 'On the structural difference between design tokens and semantic tokens.',
    href: '/writing/semantic-tokens'
  },
]
---

<Base title="Tanya Lathion — Product Designer & Product Manager">

  <Hero meta={['Valais, Switzerland', 'UX · UI · Design Systems · Product Lifecycle']} />

  <section class="section">
    <div class="section__header">
      <span class="section__label">Case studies</span>
      <span class="section__count">0{workItems.length}</span>
    </div>
    {cases.map(c => <CaseItem {...c} />)}
  </section>
